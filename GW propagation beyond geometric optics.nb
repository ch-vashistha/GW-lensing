             RowBox[{"-", "a"}], ",", 
             RowBox[{"-", "b"}]}], "]"}], " ", 
           RowBox[{"nkB", "[", 
            RowBox[{"a", ",", "b"}], "]"}]}], ",", 
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}]}], "}"}], ",", 
        RowBox[{"MetricOn", "\[Rule]", "All"}], ",", 
        RowBox[{"ContractMetrics", "\[Rule]", "True"}], ",", 
        RowBox[{"UseSymmetries", "\[Rule]", "True"}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"MakeRule", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"kmB", "[", 
            RowBox[{
             RowBox[{"-", "a"}], ",", 
             RowBox[{"-", "b"}]}], "]"}], " ", 
           RowBox[{"nlB", "[", 
            RowBox[{"a", ",", "b"}], "]"}]}], ",", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "/", "2"}], ")"}]}], "}"}], ",", 
        RowBox[{"MetricOn", "\[Rule]", "All"}], ",", 
        RowBox[{"ContractMetrics", "\[Rule]", "True"}], ",", 
