Cell[TextData[{
 "The only non-zero contractions (6 in number) of the basis tensors are \
provided in ",
 StyleBox["basisOrthogonality",
  FontWeight->"Bold"],
 " rules. Immediately follow it up with ",
 StyleBox["basisZeroContractions",
  FontWeight->"Bold"],
 " to eliminate all other scalar contractions (100 - 6 = 94 in number)"
}], "Text",
 CellChangeTimes->{{3.9838107179539394`*^9, 3.9838107934947214`*^9}, {
  3.983833007418391*^9, 3.9838330090474625`*^9}},
 FontColor->RGBColor[
  0, 0, 1],ExpressionUUID->"86d3ac3a-5d03-40b8-8a5c-9a37fd214a6e"],

Cell["\<\
To obtain (50)-(59), substitute the decomposition of epsilon in (15), and \
separately contract with each of the basis tensors. \
\>", "Text",
 CellChangeTimes->{{3.983810825579938*^9, 3.9838108907979975`*^9}},
 FontColor->RGBColor[
  0, 0, 1],ExpressionUUID->"55225960-0dbe-4286-ab57-ae7768ef20cc"],

